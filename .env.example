# Django
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True

# Database (leave as-is for SQLite local dev)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Celery (Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DingTalk (leave empty for Demo mode)
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_CORP_ID=
DINGTALK_OAUTH_REDIRECT_URI=

# Set to True for local dev without DingTalk credentials
DINGTALK_DEMO_MODE=True
